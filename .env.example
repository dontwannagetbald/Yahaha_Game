# Frontend: browser-facing API base URL.
# Leave VITE_API_BASE_URL empty in local dev so the browser calls same-origin /api
# and Vite proxies the request to VITE_API_PROXY_TARGET.
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:8000

# Backend: local API bind host and port.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL: local database settings and async SQLAlchemy URL.
POSTGRES_DB=yahaha_game
POSTGRES_USER=yahaha
POSTGRES_PASSWORD=change-me-local
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://yahaha:change-me-local@db:5432/yahaha_game

# MinIO: S3-compatible object storage for uploads, drafts, and published bundles.
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_ACCESS_KEY=change-me-local
MINIO_SECRET_KEY=change-me-local
MINIO_BUCKET=yahaha-game
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# Session: server-side session cookie signing and lifetime.
SESSION_SECRET=change-me-local-session-secret
SESSION_COOKIE_NAME=yahaha_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=604800

# Model provider: choose mock for local/CI or openai-compatible for real generation.
MODEL_PROVIDER=mock
AGENT_RUNNER=fake
MOCK_PROVIDER_ENABLED=true
LLM_PROVIDER=mock

# OpenAI-compatible API: required only when MODEL_PROVIDER=openai-compatible.
OPENAI_COMPATIBLE_BASE_URL=https://api.example.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=example-model
CODING_AGENT_MODEL=gpt-5.5
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=180
LLM_TIMEOUT_SECONDS=180

# Image provider for Asset Agent. Set ASSET_IMAGE_PROVIDER=openai-compatible
# to generate/refine background/player/cover images with the configured image model.
ASSET_IMAGE_PROVIDER=mock
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=
OPENAI_IMAGE_MODEL=
OPENAI_IMAGE_TIMEOUT_SECONDS=180
OPENAI_IMAGE_QUALITY=auto
OPENAI_IMAGE_BACKGROUND_SIZE=1280x720
OPENAI_IMAGE_PLAYER_SOURCE_SIZE=1024x1024

# LangGraph/LangSmith: used by lan_agents conversation graph when called from backend.
LAN_AGENTS_SRC_PATH=/app/lan_agents/src
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=yahaha-game
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Google OAuth: required for MVP Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# GitHub OAuth: reserved for a later implementation.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/oauth/github/callback
